<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions yang dibutuhkan -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".FoodOrderApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoodOrderApp"
        tools:targetApi="31">
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FoodOrderApp.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.BuyerDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.FoodDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.OrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.EditProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.ChangePasswordActivity"
            android:exported="false" />

        <activity
            android:name=".ui.seller.SellerDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.seller.ImagePickerDemoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.seller.AddEditMenuActivity"
            android:exported="false" />

        <activity
            android:name=".ui.seller.EditStoreProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.UserDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.AdminOrdersActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.EditAdminProfileActivity"
            android:exported="false" />

        <activity
            android:name=".ui.buyer.WriteReviewActivity"
            android:exported="false" />

    </application>

</manifest>